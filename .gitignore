# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
/package-lock.json
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# data — external files di luar project scope, tidak perlu di-repo
/data

skills-lock.json
AGENTS.md
CLAUDE.md

# supabase local state — spesifik environment, jangan di-commit
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# ignore all markdown files except README.md
*.md
**/*.md
!README.md
!**/README.md
